# Values for Coolify's Environment Variables tab (not a mounted file).

SITE_ROOT=https://hc.example.com
SITE_NAME=Watchtower
# Must include localhost: the image's Docker healthcheck curls localhost, and
# Django answers it 400 (DisallowedHost) otherwise -> container "unhealthy" ->
# Coolify's Traefik refuses to route to it (404 + no TLS cert).
ALLOWED_HOSTS=hc.example.com,localhost,127.0.0.1

# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CHANGE-ME

# Telegram alerts. TELEGRAM_BOT_NAME is the bot's @username without @.
# The app reads TELEGRAM_TOKEN (not TELEGRAM_BOT_TOKEN — common gotcha).
# See README step 7 — webhook claim; dedicated bot recommended if the main
# bot serves another webhook app.
TELEGRAM_TOKEN=
TELEGRAM_BOT_NAME=
