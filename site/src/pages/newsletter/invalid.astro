---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/home/SiteHeader.astro";
import SiteFooter from "../../components/home/SiteFooter.astro";
---
<BaseLayout title="Confirmation link expired · Behind the Watt" description="Request a fresh BTW Weekly confirmation email." canonical="https://behindthewatt.com/newsletter/invalid/">
  <SiteHeader />
  <main class="newsletter-result"><div><div class="kicker">BTW Weekly</div><h1>That link has expired.</h1><p>No address was added. Return to the subscription form and request a fresh confirmation email.</p><a class="btn btn-primary" href="/#subscribe">Try again</a></div></main>
  <SiteFooter />
</BaseLayout>
