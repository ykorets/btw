---
const { sources } = Astro.props;
---
<section><div class="wrap"><div class="eyebrow">Provenance</div><h2>Receipts for the facts</h2><p class="intro">These are the claim-to-document joins currently present in the public mirror. Missing field-level receipts remain explicitly missing.</p><div class="receipts">{sources.length ? sources.map((source: any) => <article class="receipt"><div class="eyebrow">{source.label}</div><h3>Published source</h3>{source.factsLabel && <p>Supports: {source.factsLabel}</p>}{source.quote && <><blockquote>“{source.quote}”</blockquote><div class="receipt-meta">Anchored quote{source.page ? ` · page ${source.page}` : ""}</div></>}<a class="text-link" href={source.url} target="_blank" rel="noopener">Open the receipt ↗</a></article>) : <p class="muted">No public receipts exported.</p>}</div></div></section>
