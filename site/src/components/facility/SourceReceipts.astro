---
const { sources } = Astro.props;
---
<section><div class="wrap"><div class="eyebrow">Provenance</div><h2>Receipts for the facts</h2><p class="intro">Each receipt keeps the publisher’s original URL and an immutable BTW archive record. Public copies appear only when redistribution has been approved.</p><div class="receipts">{sources.length ? sources.map((source: any) => <article class="receipt"><div class="eyebrow">{source.label}</div><h3>Published source</h3>{source.factsLabel && <p>Supports: {source.factsLabel}</p>}{source.quote && <><blockquote>“{source.quote}”</blockquote><div class="receipt-meta">Anchored quote{source.page ? ` · page ${source.page}` : ""}</div></>}<div class="receipt-meta">{source.archiveStatusLabel}{source.archived_at ? ` · captured ${String(source.archived_at).slice(0, 10)}` : ""}</div>{source.checksumLabel && <code class="checksum">{source.checksumLabel}</code>}<div class="receipt-links"><a class="text-link" href={source.url} target="_blank" rel="noopener">Source ↗</a>{source.archive_url && <a class="text-link" href={source.archive_url} target="_blank" rel="noopener">Archived copy ↗</a>}</div></article>) : <p class="muted">No public receipts exported.</p>}</div></div></section>
