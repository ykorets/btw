---
const endpoint = "https://mcp.behindthewatt.com/mcp";
const registryName = "io.github.ykorets/behind-the-watt";
const codexCommand = `codex mcp add behind-the-watt --url ${endpoint}`;
const claudeCommand = `claude mcp add --transport http --scope user behind-the-watt ${endpoint}`;
---
<section class="mcp-connect" id="connect-mcp">
  <div class="wrap">
    <div class="mcp-connect-head">
      <div>
        <div class="kicker">Live agent interface</div>
        <h2>Connect MCP</h2>
        <p class="sub">Give an AI agent direct, read-only access to verified facilities, dossiers, announcements and dataset totals. No API key or signup.</p>
      </div>
      <div class="mcp-status" aria-label="MCP server status">
        <span><i></i> Live</span>
        <span>Streamable HTTP</span>
        <span>Read-only</span>
      </div>
    </div>

    <div class="mcp-endpoint">
      <div>
        <span>Endpoint</span>
        <code>{endpoint}</code>
      </div>
      <button class="btn mcp-copy" type="button" data-mcp-copy={endpoint} aria-label="Copy MCP endpoint">Copy endpoint</button>
    </div>

    <div class="mcp-client-grid">
      <article class="mcp-client">
        <div class="mcp-client-title"><span>01</span><h3>Codex</h3></div>
        <p>Add it once from the terminal. Codex CLI, the IDE extension and the desktop app share the same MCP configuration.</p>
        <div class="mcp-command">
          <pre><code>{codexCommand}</code></pre>
          <button class="btn mcp-copy" type="button" data-mcp-copy={codexCommand} aria-label="Copy Codex command">Copy</button>
        </div>
        <small>Then open <code>/mcp</code> to confirm the four tools.</small>
      </article>

      <article class="mcp-client">
        <div class="mcp-client-title"><span>02</span><h3>Claude</h3></div>
        <p>Use the command for Claude Code, or add the same endpoint as a custom connector in Claude, Cowork or Claude Desktop.</p>
        <div class="mcp-command">
          <pre><code>{claudeCommand}</code></pre>
          <button class="btn mcp-copy" type="button" data-mcp-copy={claudeCommand} aria-label="Copy Claude Code command">Copy</button>
        </div>
        <small>Claude Code: run <code>claude mcp list</code>. Apps: <b>Customize → Connectors → Add custom connector</b>.</small>
        <a class="text-link" href="https://support.claude.com/en/articles/11175166-get-started-with-custom-connectors-using-remote-mcp" target="_blank" rel="noopener">Remote connector guide ↗</a>
      </article>
    </div>

    <div class="mcp-details">
      <div><span>Other MCP clients</span><b>Use these connection details</b></div>
      <dl>
        <div><dt>Transport</dt><dd><code>streamable-http</code></dd></div>
        <div><dt>URL</dt><dd><code>{endpoint}</code></dd></div>
        <div><dt>Authentication</dt><dd>None</dd></div>
        <div><dt>Registry</dt><dd><a href={`https://registry.modelcontextprotocol.io/?q=${encodeURIComponent(registryName)}`} target="_blank" rel="noopener">{registryName} ↗</a></dd></div>
      </dl>
    </div>

    <p class="mcp-copy-status" aria-live="polite"></p>
  </div>
</section>

<script>
  const status = document.querySelector<HTMLElement>(".mcp-copy-status");
  async function copyText(value: string) {
    await navigator.clipboard.writeText(value);
  }
  document.querySelectorAll<HTMLButtonElement>("[data-mcp-copy]").forEach((button) => {
    button.addEventListener("click", async () => {
      const value = button.dataset.mcpCopy;
      if (!value) return;
      try {
        await copyText(value);
        const label = button.textContent;
        button.textContent = "Copied";
        if (status) status.textContent = "Copied to clipboard.";
        window.setTimeout(() => {
          button.textContent = label;
          if (status) status.textContent = "";
        }, 1600);
      } catch {
        if (status) status.textContent = "Copy failed. Select the command manually.";
      }
    });
  });
</script>
